# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Node.js dependencies (re-installed inside the image) ─────────────────────
node_modules

# ── Next.js build artefacts (rebuilt inside the image) ───────────────────────
.next
out
build

# ── Environment files (secrets must be passed via build-args / env vars) ─────
.env
.env.*
!.env.example

# ── Dev tooling & editor files ────────────────────────────────────────────────
.vscode
.idea
*.tsbuildinfo
coverage
docs

# ── OS / misc ─────────────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Docker files themselves ───────────────────────────────────────────────────
Dockerfile
.dockerignore
